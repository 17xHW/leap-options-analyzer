#!/bin/bash

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "======================================"
echo " Starting LEAP Options Analyzer..."
echo "======================================"

echo "-> Starting Backend API (Port 8001)..."
cd "$PROJECT_DIR/backend"
fuser -k 8001/tcp 2>/dev/null

# Activate venv if it exists, otherwise just run python3
if [ -d "venv" ]; then
    source venv/bin/activate
fi
nohup python3 -m uvicorn main:app --port 8001 > /dev/null 2>&1 &

echo "-> Starting Frontend Dashboard (Port 5173)..."
cd "$PROJECT_DIR/frontend"
fuser -k 5173/tcp 2>/dev/null

# Launch Vite
nohup npm run dev > /dev/null 2>&1 &

# Disown background jobs
disown -a

echo "-> Opening browser..."
sleep 2
if command -v xdg-open > /dev/null; then
    xdg-open "http://localhost:5173" > /dev/null 2>&1 &
elif command -v open > /dev/null; then
    open "http://localhost:5173" > /dev/null 2>&1 &
fi
